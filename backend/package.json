    "ingest:safescope:osha-1926": "ts-node src/safescope-knowledge/ingestion/run-osha-ecfr-ingestion.ts osha-ecfr-1926 osha-ecfr-1926.json",
    "verify:standards-intelligence": "ts-node src/safescope-v2/standards-intelligence/verify-standards-intelligence.ts",
    "verify:safescope-ingestion-sources": "ts-node src/safescope-knowledge/ingestion/verify-safescope-ingestion-sources.ts",
    "verify:safescope-source-registry": "ts-node src/safescope-knowledge/sources/verify-source-registry.ts",
    "verify:safescope-knowledge-review": "ts-node src/safescope-knowledge/maintenance/verify-knowledge-review-workflow.ts",
    "verify:safescope-connector-priorities": "ts-node src/safescope-knowledge/maintenance/verify-connector-priority-planner.ts",
    "verify:safescope-ingestion-control-plane": "ts-node src/safescope-knowledge/maintenance/verify-ingestion-control-plane.ts",
    "verify:standards-source-metadata": "ts-node src/safescope-v2/standards-intelligence/verify-standards-source-metadata.ts",
    "ensure:standards-master": "ts-node src/standards/maintenance/ensure-standards-master-table.ts",
    "enrich:standards-master": "ts-node src/standards/maintenance/enrich-standards-master.ts",
    "ingest:standards:ecfr": "ts-node src/standards/ingestion/ingest-ecfr-standards.ts",
    "verify:safescope-source-roles": "ts-node src/safescope-knowledge/maintenance/verify-knowledge-source-roles.ts",
    "verify:safescope-source-synthesis": "ts-node src/safescope-knowledge/maintenance/verify-knowledge-source-synthesis.ts",
    "verify:safescope-corrective-actions": "ts-node src/safescope-v2/maintenance/verify-corrective-action-intelligence.ts",
    "verify:safescope-source-governance": "ts-node src/safescope-knowledge/maintenance/verify-source-governance.ts",
    "verify:safescope-source-expansion": "ts-node src/safescope-knowledge/maintenance/verify-source-expansion-registry.ts",
    "verify:safescope-osha-ecfr-ingestion": "ts-node src/safescope-knowledge/maintenance/verify-osha-ecfr-ingestion.ts",
