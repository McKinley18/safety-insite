    "export:safescope-knowledge": "ts-node src/safescope-knowledge/export/export-knowledge-bundle.ts",
    "seed:safescope-sources": "ts-node src/safescope-knowledge/ingestion/seed-knowledge-sources.ts",
    "ingest:safescope:msha-fatalities": "ts-node src/safescope-knowledge/ingestion/run-msha-fatality-ingestion.ts",
    "verify:safescope-msha-30-cfr-ingestion": "ts-node src/safescope-knowledge/maintenance/verify-msha-30-cfr-ingestion.ts",
