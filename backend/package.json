    "source:intelligence:validate-governance": "npm run source:intelligence:validate-preview && npm run source:intelligence:validate-orchestrator-contract && npm run source:intelligence:validate-adapter-contracts && npm run source:intelligence:validate-mock-source-adapter && npm run source:intelligence:validate-orchestrator-mock-source-flow && npm run source:intelligence:validate-real-source-adapter && npm run source:intelligence:validate-orchestrator-real-source-flow && npm run source:intelligence:validate-hazard-classification-adapter && npm run source:intelligence:validate-orchestrator-hazard-classification-flow",
    "source:intelligence:validate-adapter-contracts": "ts-node scripts/validate-safescope-adapter-contracts.ts",
    "source:intelligence:validate-mock-source-adapter": "ts-node scripts/validate-safescope-mock-source-adapter.ts",
    "source:intelligence:validate-orchestrator-mock-source-flow": "ts-node scripts/validate-safescope-orchestrator-with-mock-source.ts",
    "source:intelligence:validate-real-source-adapter": "ts-node scripts/validate-safescope-real-source-adapter.ts",
    "source:intelligence:validate-orchestrator-real-source-flow": "ts-node scripts/validate-safescope-orchestrator-with-real-source.ts",
    "source:intelligence:validate-hazard-classification-adapter": "ts-node scripts/validate-safescope-hazard-classification-adapter.ts",
    "source:intelligence:validate-orchestrator-hazard-classification-flow": "ts-node scripts/validate-safescope-orchestrator-with-hazard-classification.ts",
    "source:intelligence:validate-standards-matching-adapter": "ts-node scripts/validate-safescope-standards-matching-adapter.ts"
  },
  "dependencies": {
