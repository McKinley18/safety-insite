    "test:classify": "ts-node src/test-classify.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "ingest:msha": "ts-node src/standards/ingestion/ingest.ts",
    "ingest:cfr:bulk": "ts-node src/standards/ingestion/ingest.cfr.bulk.ts",
    "clean:cfr": "ts-node src/standards/ingestion/clean.cfr.ts",
    "test:safescope": "ts-node src/safescope-v2/tests/golden-hazard-tests.ts",
    "seed:safescope-standards": "ts-node src/safescope-v2/standards/safescope-standards.seed.ts",
    "test:safescope-standards": "ts-node src/safescope-v2/tests/golden-standards-tests.ts",
