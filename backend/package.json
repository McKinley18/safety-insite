    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/puppeteer": "^5.4.7",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "nodemon": "^3.0.0",
