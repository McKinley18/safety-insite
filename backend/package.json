    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "fast-xml-parser": "^5.8.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "natural": "^8.1.1",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "puppeteer": "^24.43.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "stripe": "^22.1.1",
    "typeorm": "^0.3.29",
    "uuid": "^14.0.0",
    "xml2js": "^0.6.2"
  },
